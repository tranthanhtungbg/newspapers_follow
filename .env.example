# =============================================================
# LingoReader — Environment Variables Template
# Copy this file to .env and fill in the actual values.
# NEVER commit .env to version control.
# =============================================================

# -------------------------
# App
# -------------------------
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_PORT=3001

# -------------------------
# PostgreSQL
# -------------------------
POSTGRES_DB=lingoreader
POSTGRES_USER=lingoreader_user
POSTGRES_PASSWORD=lingoreader_secret
POSTGRES_PORT=5432
DATABASE_URL=postgresql://lingoreader_user:lingoreader_secret@localhost:5432/lingoreader

# -------------------------
# Redis
# -------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379

# -------------------------
# MinIO (S3-Compatible Storage)
# -------------------------
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_secret_123

# S3 config for the app (NestJS)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio_admin
S3_SECRET_KEY=minio_secret_123
S3_BUCKET_AUDIO=lingoreader-audio
S3_BUCKET_BACKUPS=lingoreader-backups
S3_PUBLIC_URL=http://localhost:9000/lingoreader-audio

# -------------------------
# JWT
# -------------------------
JWT_ACCESS_SECRET=replace_me_with_a_very_long_random_string_access
JWT_REFRESH_SECRET=replace_me_with_a_very_long_random_string_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -------------------------
# OAuth
# -------------------------
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# -------------------------
# AI / Translation
# -------------------------
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4o

# -------------------------
# TTS
# -------------------------
GOOGLE_TTS_API_KEY=your_google_tts_api_key

# -------------------------
# Email (Nodemailer)
# -------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=LingoReader <noreply@lingoreader.io>

# -------------------------
# Sentry (Error Tracking)
# -------------------------
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project

# -------------------------
# Next.js Public Variables (Frontend)
# -------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MINIO_PUBLIC_URL=http://localhost:9000/lingoreader-audio
